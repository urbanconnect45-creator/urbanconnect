{
  "installCommand": "npm ci",
  "buildCommand": "npm run export:web",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/admin-portal",
      "destination": "/admin-portal/index.html"
    },
    {
      "source": "/admin-portal/(.*)",
      "destination": "/admin-portal/index.html"
    },
    {
      "source": "/app",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/(.*)",
      "destination": "/app/index.html"
    }
  ]
}
